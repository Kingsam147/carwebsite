# ── Supabase Postgres ─────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → Database → Connection string
# Use the "Transaction" pooler URL for DATABASE_URL (port 6543, pgbouncer=true)
# Use the "Session" pooler or direct URL for DIRECT_URL (port 5432)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Supabase Auth & API ───────────────────────────────────────────────────────
# Found in: Supabase dashboard → Settings → API
SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Client-side Supabase (same values — NEXT_PUBLIC_ prefix exposes them to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ── Admin Authentication ──────────────────────────────────────────────────────
# Email address of the Supabase Auth user with admin access
# Create this user in: Supabase dashboard → Authentication → Users → Add user
ADMIN_EMAIL="admin@yourdomain.com"

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local development: redis://localhost:6379
# Docker Compose:    redis://redis:6379
REDIS_URL="redis://localhost:6379"

# ── Access Control ───────────────────────────────────────────────────────────
# Secret token that gates access to the site (proxy.ts)
# Portfolio link format: https://yourproject.vercel.app?access=YOUR_TOKEN
# Visitors without the token or a valid session cookie receive a 403
# Leave empty to disable access control (localhost is always allowed)
ACCESS_TOKEN="generate-a-random-secret-here"
# URL of the portfolio site — visitors arriving from this domain bypass the access token
PORTFOLIO_ORIGIN="https://your-portfolio.vercel.app"

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Found in: Cloudflare dashboard → My Profile → API Tokens
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
# Found in: Cloudflare dashboard → right sidebar on the main page
CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
# Found in: Cloudflare dashboard → your domain → Overview → right sidebar
CLOUDFLARE_ZONE_ID="your-cloudflare-zone-id"
# The production domain — used for WAF origin restriction rules
ALLOWED_ORIGIN="https://yourdomain.com"
